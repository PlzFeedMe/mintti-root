# Mintti multi-host deployment mapping.
#
# Edit this file to switch between an all-on-ilmo dev layout and the split-host
# layout where shared services move to aimo.

# Dev profile:
MINTTI_DEPLOY_CONTROL_SSH_TARGET=ilmo-1
MINTTI_DEPLOY_SHARED_SSH_TARGET=ilmo-1
MINTTI_SHARED_API_BASE_URL=http://ilmo-1:8000

# Split-host profile example:
# MINTTI_DEPLOY_CONTROL_SSH_TARGET=ilmo-1
# MINTTI_DEPLOY_SHARED_SSH_TARGET=aimo-1
# MINTTI_SHARED_API_BASE_URL=http://aimo-1:8000

# Default customer VM target. Override per customer inventory when needed.
MINTTI_DEPLOY_CUSTOMER_DEFAULT_SSH_TARGET=timo-1

# Default remote checkout path used by all inventories unless overridden.
MINTTI_DEPLOY_DEFAULT_ROOT=/srv/mintti-root
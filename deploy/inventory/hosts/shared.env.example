DEPLOY_HOST=shared
DEPLOY_SSH_TARGET=${MINTTI_DEPLOY_SHARED_SSH_TARGET:-ilmo-1}
DEPLOY_ROLE=aimo-shared
DEPLOY_ROOT=${MINTTI_DEPLOY_DEFAULT_ROOT:-/srv/mintti-root}
DEPLOY_COMPOSE_FILE=deploy/compose/aimo-shared.compose.yaml
DEPLOY_STACK_NAME=mintti-shared

MINTTI_BACKGROUND_PORT=8000
MINTTI_COD_DB_PORT=5432
MINTTI_COD_DB_NAME=coddb
MINTTI_COD_DB_USER=coddbuser
MINTTI_COD_DB_PASSWORD=replace-me
MINTTI_COD_CIFS_HOST_PATH=/srv/mintti/cod-cifs
MINTTI_COD_CIFS_CONTAINER_PATH=/workspace/cod-cifs
MINTTI_COD_METADATA_HOST_PATH=/srv/mintti/cod-metadata
MINTTI_COD_METADATA_CONTAINER_PATH=/workspace/cod-metadata